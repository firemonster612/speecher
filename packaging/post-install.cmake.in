if(NOT "$ENV{DESTDIR}" STREQUAL "")
  return()
endif()

find_program(SPEECHER_UPDATE_DESKTOP_DATABASE update-desktop-database)
if(SPEECHER_UPDATE_DESKTOP_DATABASE)
  execute_process(
    COMMAND "${SPEECHER_UPDATE_DESKTOP_DATABASE}" "${CMAKE_INSTALL_PREFIX}/@SPEECHER_INSTALL_APPLICATIONS_DIR@"
    RESULT_VARIABLE SPEECHER_UPDATE_DESKTOP_DATABASE_RESULT
    OUTPUT_QUIET
    ERROR_QUIET
  )
endif()

find_program(SPEECHER_GTK_UPDATE_ICON_CACHE gtk-update-icon-cache)
if(SPEECHER_GTK_UPDATE_ICON_CACHE)
  execute_process(
    COMMAND "${SPEECHER_GTK_UPDATE_ICON_CACHE}" -q -t -f "${CMAKE_INSTALL_PREFIX}/@SPEECHER_INSTALL_HICOLOR_DIR@"
    RESULT_VARIABLE SPEECHER_GTK_UPDATE_ICON_CACHE_RESULT
    OUTPUT_QUIET
    ERROR_QUIET
  )
endif()

find_program(SPEECHER_KBUILD_SYCOCA kbuildsycoca6 kbuildsycoca5)
if(SPEECHER_KBUILD_SYCOCA)
  execute_process(
    COMMAND "${SPEECHER_KBUILD_SYCOCA}" --noincremental
    RESULT_VARIABLE SPEECHER_KBUILD_SYCOCA_RESULT
    OUTPUT_QUIET
    ERROR_QUIET
  )
endif()
